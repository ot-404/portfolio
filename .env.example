# Copy this file to ".env" and fill in real values for local development.
# .env is git-ignored — never commit real credentials.
# On Render, set these in the dashboard (Environment tab) instead.

# Used to sign the session cookie (flash messages). Use any long random string.
SECRET_KEY=change-me-to-something-random

# --- Contact-form email (SMTP) ---
# Works with any SMTP provider. Example below uses Brevo (free tier).
# Get these from Brevo: dashboard -> "SMTP & API" -> SMTP tab.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
# Brevo "Login" value (shown on the SMTP page) — usually your account email.
SMTP_USER=your-brevo-login
# Brevo "SMTP key" (generate one on that page). NOT your account password.
SMTP_PASSWORD=your-brevo-smtp-key
# The visible "From" address. Must be a sender you've VERIFIED in Brevo.
SMTP_FROM=opshokare@gmail.com
# Where submissions are delivered (defaults to the PROFILE email if unset).
CONTACT_TO=opshokare@gmail.com
# Set to "false" only for a local non-TLS test mail server.
SMTP_USE_TLS=true
